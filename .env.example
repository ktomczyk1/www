# Wklej klucz z Stripe Dashboard → Developers → API keys → Secret key (zaczyna się od sk_test_...)
STRIPE_SECRET_KEY=sk_test_wklej_tutaj

# Publishable key (pk_test_...) NIE jest potrzebny w tym projekcie — płatność idzie przez przekierowanie na stronę Stripe.

# Webhook secret (whsec_...) — OPCJONALNY przy testach lokalnych.
# Status „opłacone” ustawia się też po powrocie ze Stripe (success URL).
# Webhook potrzebujesz dopiero na produkcji lub jeśli chcesz potwierdzać płatność bez powrotu użytkownika.
# Lokalnie: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

APP_URL=http://localhost:3000
